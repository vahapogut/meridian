  },
  "dependencies": {
    "@meridian-sync/shared": "workspace:*",
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "fake-indexeddb": "^6.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0"
}
