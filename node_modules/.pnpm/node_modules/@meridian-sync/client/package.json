{
  "name": "@meridian-sync/client",
  "version": "0.1.0",
  "description": "Local-first sync client for Meridian — IndexedDB + WebSocket + CRDT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
