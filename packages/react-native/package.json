{
  "name": "@meridian-sync/react-native",
  "version": "0.4.0",
  "description": "React Native client for Meridian — local-first sync with SQLite/AsyncStorage",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --external react --external react-native",
    "test": "vitest run --passWithNoTests",
    "dev": "tsup src/index.ts --format esm,cjs --watch --external react --external react-native"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "^0.72.0"
  },
  "dependencies": {
    "@meridian-sync/client": "workspace:*",
    "@meridian-sync/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^1.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-native": "^0.76.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vahapogut/meridian"
  },
  "keywords": ["react-native", "meridian", "sync", "local-first", "offline-first", "crdt", "mobile"],
  "author": "Abdulvahap OGUT <info@ipeclabs.com>"
}
