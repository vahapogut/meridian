{
  "name": "meridiandb-cli",
  "version": "0.2.0",
  "description": "CLI tools for Meridian — migrate, inspect, replay, status",
  "main": "./dist/index.js",
  "bin": {
    "meridian": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/cli.ts --format esm",
    "test": "vitest run --passWithNoTests",
    "dev": "tsup src/cli.ts --format esm --watch"
  },
  "dependencies": {
    "meridian-server": "workspace:*",
    "meridian-shared": "workspace:*",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vahapogut/MeridianDB"
  },
  "keywords": ["meridian", "cli", "sync", "migrate", "inspect", "replay"],
  "author": "Abdulvahap OGUT <info@ipeclabs.com>"
}
