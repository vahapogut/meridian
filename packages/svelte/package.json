{
  "name": "meridian-svelte",
  "version": "0.6.0",
  "description": "Svelte 5 stores for MeridianDB — useQuery, useLiveQuery, useDoc, useSync, useMutation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --external svelte",
    "test": "vitest run --passWithNoTests",
    "dev": "tsup src/index.ts --format esm,cjs --watch --external svelte"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "meridian-client": "workspace:*",
    "meridian-shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/vahapogut/MeridianDB" },
  "keywords": ["svelte", "sveltekit", "meridian", "sync", "local-first", "realtime", "crdt"],
  "author": "Abdulvahap OGUT <info@ipeclabs.com>"
}
